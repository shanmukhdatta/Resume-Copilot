<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>{{ resume.contact.full_name }} - Resume</title>
<link rel="stylesheet" href="{{ css_path }}">
</head>
<body>
  <header>
    <h1>{{ resume.contact.full_name }}</h1>
    <p class="contact-line">
      {{ resume.contact.email }} {% if resume.contact.phone %}| {{ resume.contact.phone }}{% endif %}
      {% if resume.contact.location %}| {{ resume.contact.location }}{% endif %}
    </p>
    {% if resume.links %}
    <p class="links-line">
      {% for link in resume.links %}<a href="{{ link.url }}">{{ link.label }}</a>{% if not loop.last %} · {% endif %}{% endfor %}
    </p>
    {% endif %}
  </header>

  {% if resume.summary %}
  <section>
    <h2>Summary</h2>
    <p>{{ resume.summary }}</p>
  </section>
  {% endif %}

  {% if resume.skills %}
  <section>
    <h2>Skills</h2>
    {% for cat in resume.skills %}
    <p><strong>{{ cat.category }}:</strong> {{ cat.skills | join(', ') }}</p>
    {% endfor %}
  </section>
  {% endif %}

  {% if resume.experience %}
  <section>
    <h2>Experience</h2>
    {% for exp in resume.experience %}
    <div class="entry">
      <div class="entry-header">
        <span class="entry-title">{{ exp.title }}, {{ exp.company }}</span>
        <span class="entry-dates">{{ exp.start_date }} - {{ exp.end_date }}</span>
      </div>
      <ul>{% for bullet in exp.bullets %}<li>{{ bullet }}</li>{% endfor %}</ul>
    </div>
    {% endfor %}
  </section>
  {% endif %}

  {% if resume.projects %}
  <section>
    <h2>Projects</h2>
    {% for proj in resume.projects %}
    <div class="entry">
      <div class="entry-header"><span class="entry-title">{{ proj.name }}</span></div>
      {% if proj.description %}<p>{{ proj.description }}</p>{% endif %}
      <ul>{% for bullet in proj.bullets %}<li>{{ bullet }}</li>{% endfor %}</ul>
      {% if proj.technologies %}<p class="tech-line">{{ proj.technologies | join(', ') }}</p>{% endif %}
    </div>
    {% endfor %}
  </section>
  {% endif %}

  {% if resume.education %}
  <section>
    <h2>Education</h2>
    {% for edu in resume.education %}
    <div class="entry">
      <div class="entry-header">
        <span class="entry-title">{{ edu.degree }}, {{ edu.institution }}</span>
        <span class="entry-dates">{{ edu.start_date }} - {{ edu.end_date }}</span>
      </div>
      {% if edu.gpa %}<p>GPA: {{ edu.gpa }}</p>{% endif %}
    </div>
    {% endfor %}
  </section>
  {% endif %}

  {% if resume.certifications %}
  <section>
    <h2>Certifications</h2>
    <ul>{% for c in resume.certifications %}<li>{{ c.name }} — {{ c.issuer }} ({{ c.date }})</li>{% endfor %}</ul>
  </section>
  {% endif %}

  {% if resume.achievements %}
  <section>
    <h2>Achievements</h2>
    <ul>{% for a in resume.achievements %}<li>{{ a.title }}: {{ a.description }}</li>{% endfor %}</ul>
  </section>
  {% endif %}
</body>
</html>
